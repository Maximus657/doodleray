{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DoodleRay",
  "version": "2.0.0",
  "identifier": "com.doodlevpn.doodleray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DoodleRay VPN",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "exceptionDomain": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGNENGODYxOURERUQ3OQpSV1I1N2QwWmhzLzBCTFRnMkVJSDhlOVZjTTNlWTZsb3F5UFNpK3BkdTlJVno0cjBCbjhhRitxSAo=",
      "endpoints": [
        "https://github.com/Maximus657/doodleray/releases/latest/download/latest.json"
      ]
    }
  }
}
